# ============================================
# Questcast Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- REQUIRED ---

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/questcast

# OpenAI (for STT, LLM, TTS, Image generation)
OPENAI_API_KEY=sk-your-key

# JWT (must be at least 32 characters)
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long

# --- OPTIONAL (have defaults) ---

# Server
PORT=3000                    # default: 3000
NODE_ENV=development         # default: development (options: development, staging, production, test)
CORS_ORIGIN=*                # default: * (restrict in production)

# Redis (Upstash) - optional, falls back to in-memory if unavailable
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# Supabase Auth - optional for local dev (email/password auth works without it)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Sentry (error tracking) - optional, disabled if empty
SENTRY_DSN=

# Cost monitoring
DAILY_AI_COST_ALERT_THRESHOLD=50   # default: 50 (USD)
