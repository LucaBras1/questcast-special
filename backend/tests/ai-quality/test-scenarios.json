    "id": "scenario-13",
    "name": "Long Session: Turn 25+ Coherence with Summary",
    "description": "Deep into a session at turn 27. Tests whether the AI maintains coherence using the narrative summary as long-term memory. The narrative summary references specific past events that the AI should stay consistent with.",
    "language": "en",
    "playerInput": "I return to the village elder to report what I found in the ruins.",
    "gameState": {
      "characterName": "Aria",
      "characterClass": "ranger",
      "currentLocation": "Thornwall Village",
      "activeQuest": "Uncover the Source of the Blight",
      "turnsPlayed": 27,
      "questProgress": 0.65,
      "narrativeSummary": "Aria arrived in Thornwall Village and learned from Elder Maren that crops were dying from an unknown blight. She tracked the corruption to the Whispering Ruins east of the village where she discovered a shattered ward stone leaking dark energy. She fought off corrupted wolves guarding the ruins and found an inscription suggesting the ward was deliberately broken by someone from the village. She collected a fragment of the ward stone as evidence.",
      "npcs_met": ["Elder Maren", "Farmer Gregor", "The Herbalist"],
      "inventory": ["Ward stone fragment", "Longbow", "Healing herbs", "Lantern"]
    },
    "expectedBehavior": {
      "shouldMentionCharacter": false,
      "shouldMentionLocation": true,
      "minWords": 50,
      "maxWords": 150,
      "expectedLanguage": "en",
      "shouldRequireDice": false,
      "shouldBeNarrative": true,
      "shouldReferenceNarrativeSummary": true,
      "expectedNPCReference": "Elder Maren"
    }
  },
