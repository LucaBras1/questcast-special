{
  "name": "questcast",
  "version": "0.1.0",
  "private": true,
  "description": "AI Voice RPG - Your AI Dungeon Master in Your Pocket",
  "workspaces": [
    "backend",
    "mobile",
    "shared"
  ],
  "scripts": {
    "backend:dev": "npm run dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend",
    "backend:test": "npm run test --workspace=backend",
    "mobile:start": "npm run start --workspace=mobile",
    "mobile:android": "npm run android --workspace=mobile",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "mobile/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "shared/**/*.ts": [
      "prettier --write"
    ]
  }
}
